# SaulGPT runtime configuration
OLLAMA_URL=http://localhost:11434/api/generate

# Primary and fallback models (recommended order)
OLLAMA_MODEL=mistral
OLLAMA_MODEL_CANDIDATES=mistral,llama3.1:8b-instruct,qwen2.5:7b-instruct

# Retrieval tuning
SAULGPT_USE_EMBEDDINGS=0
# Set to 1 to enable sentence-transformer+FAISS hybrid retrieval when model assets are available.

# Generation/runtime tuning
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_MAX_RETRIES=2
CHAT_MAX_TOKENS=520
GENERATE_MAX_TOKENS=900
CHAT_CACHE_TTL_SECONDS=900
REQUESTS_PER_MINUTE=30

# Security (optional)
# SAULGPT_API_KEY=change-this

# Frontend dev origins + local file:// origin
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,null
